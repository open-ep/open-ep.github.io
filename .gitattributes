# Normalize all text files to LF in the repo and on checkout (any OS)
* text=auto eol=lf

# Treat binary assets as binary so they're never line-ending-converted
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.svg  text eol=lf
*.woff  binary
*.woff2 binary
*.pdf  binary
